<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <title>Greenset Tennis Club</title>
</head>
<body>

  <h1>Greenset Tennis Club</h1>
  <p>สนามเทนนิสคุณภาพ 6 สนาม</p>

  <div>
    @each(court in courts)
      <div>
        <h3>{{ court.courtName }}</h3>
        <p>ราคา {{ court.pricePerHour }} บาท/ชั่วโมง</p>
        <p>สถานะ {{ court.status }}</p>
      </div>
    @end
  </div>

</body>
</html>